#include "main.h"
#include <stdio.h>
#include <string.h>

/* Private variables ---------------------------------------------------------*/
CAN_HandleTypeDef hcan;
UART_HandleTypeDef huart1;

/* Private function prototypes -----------------------------------------------*/
void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_CAN_Init(void);
static void MX_USART1_UART_Init(void);

/* USER CODE BEGIN PFP */
static void CAN_Filter_Config_AllPass(void);
static uint8_t CAN_Send_Frame_Std(uint16_t id, uint8_t *data, uint8_t len);
static void UART1_Print(char *msg);
static void CAN_Print_Error(void);
/* USER CODE END PFP */

int main(void)
{
  uint8_t txData[8] = {0x11, 0x22, 0x33, 0x44, 0x55, 0x66, 0x77, 0x88};

  HAL_Init();
  SystemClock_Config();

  MX_GPIO_Init();
  MX_CAN_Init();
  MX_USART1_UART_Init();

  CAN_Filter_Config_AllPass();

  if (HAL_CAN_Start(&hcan) != HAL_OK)
  {
    UART1_Print("HAL_CAN_Start failed\r\n");
    Error_Handler();
  }

  UART1_Print("CAN TX started\r\n");
  UART1_Print("CAN baud = 125 kbps\r\n");
  UART1_Print("Send STD ID 0x123 every 1000 ms\r\n");

  while (1)
  {
    if (CAN_Send_Frame_Std(0x123, txData, 8))
    {
      UART1_Print("CAN send ok: ID=0x123 DLC=8 DATA=11 22 33 44 55 66 77 88\r\n");
    }
    else
    {
      UART1_Print("CAN send failed\r\n");
      CAN_Print_Error();
    }

    HAL_Delay(1000);
  }
}

