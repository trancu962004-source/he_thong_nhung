}

static void CAN_Print_Error(void)
{
  char msg[128];
  uint32_t err = HAL_CAN_GetError(&hcan);

  snprintf(msg, sizeof(msg), "CAN error = 0x%08lX\r\n", err);
  UART1_Print(msg);
}

static void CAN_Filter_Config_AllPass(void)
{
  CAN_FilterTypeDef filter = {0};

  filter.FilterActivation = ENABLE;
  filter.FilterBank = 0;
  filter.FilterFIFOAssignment = CAN_FILTER_FIFO0;
  filter.FilterIdHigh = 0x0000;
  filter.FilterIdLow = 0x0000;
  filter.FilterMaskIdHigh = 0x0000;
  filter.FilterMaskIdLow = 0x0000;
  filter.FilterMode = CAN_FILTERMODE_IDMASK;
  filter.FilterScale = CAN_FILTERSCALE_32BIT;
  filter.SlaveStartFilterBank = 14;

  if (HAL_CAN_ConfigFilter(&hcan, &filter) != HAL_OK)
  {
    Error_Handler();
  }
}

static uint8_t CAN_Send_Frame_Std(uint16_t id, uint8_t *data, uint8_t len)
{
  CAN_TxHeaderTypeDef txHeader;
  uint32_t txMailbox;
  uint32_t tickstart;

  if (len > 8)
    len = 8;

  txHeader.StdId = id;
  txHeader.ExtId = 0;
  txHeader.IDE = CAN_ID_STD;
  txHeader.RTR = CAN_RTR_DATA;
  txHeader.DLC = len;
  txHeader.TransmitGlobalTime = DISABLE;

  /* nếu mailbox bị kẹt từ lần trước thì abort cho sạch */
  if (HAL_CAN_GetTxMailboxesFreeLevel(&hcan) == 0)
  {
    HAL_CAN_AbortTxRequest(&hcan, CAN_TX_MAILBOX0 | CAN_TX_MAILBOX1 | CAN_TX_MAILBOX2);
    HAL_Delay(2);

    if (HAL_CAN_GetTxMailboxesFreeLevel(&hcan) == 0)
    {
      return 0;
    }
  }

  if (HAL_CAN_AddTxMessage(&hcan, &txHeader, data, &txMailbox) != HAL_OK)
  {
    return 0;
  }

  /* chờ frame được truyền xong hoặc timeout */
  tickstart = HAL_GetTick();
  while (HAL_CAN_IsTxMessagePending(&hcan, txMailbox))
  {
    if ((HAL_GetTick() - tickstart) > 100)
    {
      HAL_CAN_AbortTxRequest(&hcan, txMailbox);
      return 0;
    }
  }

  if (HAL_CAN_GetError(&hcan) != HAL_CAN_ERROR_NONE)
  {
    return 0;
  }

  return 1;
}

