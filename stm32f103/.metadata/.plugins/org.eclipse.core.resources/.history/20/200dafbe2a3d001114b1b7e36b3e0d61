/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  HAL_Init();
  SystemClock_Config();

  MX_GPIO_Init();
  MX_CAN_Init();

  CAN_Filter_Config_AllPass();

  if (HAL_CAN_Start(&hcan) != HAL_OK)
  {
    Error_Handler();
  }

  while (1)
  {
    CAN_Send_Test_Frame();
    HAL_Delay(1000);
  }
}

