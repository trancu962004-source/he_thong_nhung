static void CAN_Filter_Config_AllPass(void)
{
  CAN_FilterTypeDef filter = {0};

  filter.FilterActivation = ENABLE;
  filter.FilterBank = 0;
  filter.FilterFIFOAssignment = CAN_FILTER_FIFO0;
  filter.FilterIdHigh = 0x0000;
  filter.FilterIdLow = 0x0000;
  filter.FilterMaskIdHigh = 0x0000;
  filter.FilterMaskIdLow = 0x0000;
  filter.FilterMode = CAN_FILTERMODE_IDMASK;
  filter.FilterScale = CAN_FILTERSCALE_32BIT;

  if (HAL_CAN_ConfigFilter(&hcan, &filter) != HAL_OK)
  {
    Error_Handler();
  }
}

static void UART1_Print(char *msg)
{
  HAL_UART_Transmit(&huart1, (uint8_t *)msg, strlen(msg), 100);
}

static void UART1_Print_CAN_Frame(CAN_RxHeaderTypeDef *rxHeader, uint8_t *data)
{
  char msg[128];
  int len = 0;
  uint8_t i;

  if (rxHeader->IDE == CAN_ID_STD)
  {
    len = snprintf(msg, sizeof(msg), "ID:0x%03lX DLC:%d DATA:",
                   rxHeader->StdId, rxHeader->DLC);
  }
  else
  {
    len = snprintf(msg, sizeof(msg), "ID:0x%08lX DLC:%d DATA:",
                   rxHeader->ExtId, rxHeader->DLC);
  }

  HAL_UART_Transmit(&huart1, (uint8_t *)msg, len, 100);

  for (i = 0; i < rxHeader->DLC; i++)
  {
    len = snprintf(msg, sizeof(msg), " %02X", data[i]);
    HAL_UART_Transmit(&huart1, (uint8_t *)msg, len, 100);
  }

  UART1_Print("\r\n");
}

void HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan)
{
  CAN_RxHeaderTypeDef rxHeader;
  uint8_t rxData[8];

  if (HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &rxHeader, rxData) != HAL_OK)
  {
    UART1_Print("CAN RX error\r\n");
    return;
  }

  UART1_Print_CAN_Frame(&rxHeader, rxData);
}

