}

/**
  * Hỗ trợ cả 2 dạng:
  * 1) W=A,R=3,B=2,P=1,HR=88,SPO2=97,T=36.8,BAT=90,ST=0,SEQ=10
  * 2) TYPE=VITAL,W=A,R=3,B=2,P=1,HR=88,SPO2=97,T=36.8,BAT=90,SEQ=10
  */
static uint8_t Parse_UART_Line(const char *line, PatientData_t *p)
{
    char wing = 0;
    int room = 0, bed = 0, patient = 0;
    int hr = 0, spo2 = 0, bat = 0, st = 0, seq = 0;
    float temp = 0.0f;

    int ret = 0;

    /* Format có TYPE=VITAL và không có ST */
    ret = sscanf(line,
                 "TYPE=VITAL,W=%c,R=%d,B=%d,P=%d,HR=%d,SPO2=%d,T=%f,BAT=%d,SEQ=%d",
                 &wing, &room, &bed, &patient, &hr, &spo2, &temp, &bat, &seq);

    if (ret != 9)
    {
        /* Format cũ có ST */
        ret = sscanf(line,
                     "W=%c,R=%d,B=%d,P=%d,HR=%d,SPO2=%d,T=%f,BAT=%d,ST=%d,SEQ=%d",
                     &wing, &room, &bed, &patient, &hr, &spo2, &temp, &bat, &st, &seq);

        if (ret != 10)
        {
            /* Format không TYPE và không ST */
            ret = sscanf(line,
                         "W=%c,R=%d,B=%d,P=%d,HR=%d,SPO2=%d,T=%f,BAT=%d,SEQ=%d",
                         &wing, &room, &bed, &patient, &hr, &spo2, &temp, &bat, &seq);

            if (ret != 9)
            {
                return 0;
            }
        }
    }

    if (room < 0 || room > 31) return 0;
    if (bed  < 0 || bed  > 7 ) return 0;
    if (hr   < 0 || hr   > 255) return 0;
    if (spo2 < 0 || spo2 > 255) return 0;
    if (temp < 0.0f || temp > 50.0f) return 0;

    (void)wing;
    (void)patient;
    (void)bat;
    (void)st;
    (void)seq;

    p->room = (uint8_t)room;
    p->bed  = (uint8_t)bed;
    p->hr   = (uint8_t)hr;
    p->spo2 = (uint8_t)spo2;
    p->temp_x10 = (int16_t)(temp * 10.0f + (temp >= 0 ? 0.5f : -0.5f));
    p->valid = 1;

    return 1;
}

/* source = 1: ESP1(UART2), source = 2: ESP2(UART3) */
static uint16_t Make_CAN_ID(uint8_t source, uint8_t room, uint8_t bed)
{
    uint16_t base = (source == 1) ? 0x100 : 0x200;
    return (uint16_t)(base | ((room & 0x1F) << 3) | (bed & 0x07));
}

static void Pack_Vitals(uint8_t hr, uint8_t spo2, int16_t temp_x10, uint8_t data[4])
{
    data[0] = hr;
    data[1] = spo2;
    data[2] = (uint8_t)(temp_x10 & 0xFF);
    data[3] = (uint8_t)((temp_x10 >> 8) & 0xFF);
}

static uint8_t CAN_Filter_Config_AllPass(void)
{
    CAN_FilterTypeDef filter = {0};

    filter.FilterActivation = ENABLE;
    filter.FilterBank = 0;
    filter.FilterFIFOAssignment = CAN_FILTER_FIFO0;
    filter.FilterIdHigh = 0x0000;
    filter.FilterIdLow = 0x0000;
    filter.FilterMaskIdHigh = 0x0000;
    filter.FilterMaskIdLow = 0x0000;
    filter.FilterMode = CAN_FILTERMODE_IDMASK;
    filter.FilterScale = CAN_FILTERSCALE_32BIT;

    if (HAL_CAN_ConfigFilter(&hcan, &filter) != HAL_OK)
    {
        return 0;
    }

    return 1;
}

static uint8_t CAN_Send_Vitals(uint8_t source, const PatientData_t *p)
{
    CAN_TxHeaderTypeDef txHeader;
    uint8_t data[4];
    uint32_t txMailbox;

    memset(&txHeader, 0, sizeof(txHeader));

    txHeader.StdId = Make_CAN_ID(source, p->room, p->bed);
    txHeader.ExtId = 0;
    txHeader.IDE   = CAN_ID_STD;
    txHeader.RTR   = CAN_RTR_DATA;
    txHeader.DLC   = 4;
    txHeader.TransmitGlobalTime = DISABLE;

    Pack_Vitals(p->hr, p->spo2, p->temp_x10, data);

    if (HAL_CAN_GetTxMailboxesFreeLevel(&hcan) == 0)
    {
        return 0;
    }

    if (HAL_CAN_AddTxMessage(&hcan, &txHeader, data, &txMailbox) != HAL_OK)
    {
        return 0;
    }

    return 1;
}

static void CAN_Task_One(uint8_t source,
                         const PatientData_t *p,
                         uint32_t *last_tx,
                         uint32_t tx_offset_ms)
{
    uint32_t now = HAL_GetTick();

    if (!p->valid)
        return;

    if (now < tx_offset_ms)
        return;

    if ((now - *last_tx) >= g_tx_period_ms)
    {
        *last_tx = now;

        if (CAN_Send_Vitals(source, p))
        {
            char logbuf[160];
            snprintf(logbuf, sizeof(logbuf),
                     "CAN TX | SRC=%u ID=0x%03X HR=%u SpO2=%u Temp_x10=%d\r\n",
                     source,
                     Make_CAN_ID(source, p->room, p->bed),
                     p->hr,
                     p->spo2,
                     p->temp_x10);
            UART1_Print(logbuf);
        }
        else
        {
            char logbuf[80];
            snprintf(logbuf, sizeof(logbuf), "CAN TX ERROR | SRC=%u\r\n", source);
            UART1_Print(logbuf);
        }
    }
}

void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
{
    if (huart->Instance == USART2)
    {
        if (uart2_rx_byte == '\n')
        {
            uart2_rx_line[uart2_rx_index] = '\0';
            strncpy(uart2_line_copy, uart2_rx_line, sizeof(uart2_line_copy) - 1);
            uart2_line_copy[sizeof(uart2_line_copy) - 1] = '\0';

            uart2_rx_index = 0;
            uart2_line_ready = 1;
        }
        else if (uart2_rx_byte != '\r')
        {
            if (uart2_rx_index < sizeof(uart2_rx_line) - 1)
            {
                uart2_rx_line[uart2_rx_index++] = (char)uart2_rx_byte;
            }
            else
            {
                uart2_rx_index = 0;
            }
        }

        UART2_StartReceiveIT();
    }
    else if (huart->Instance == USART3)
    {
        if (uart3_rx_byte == '\n')
        {
            uart3_rx_line[uart3_rx_index] = '\0';
            strncpy(uart3_line_copy, uart3_rx_line, sizeof(uart3_line_copy) - 1);
            uart3_line_copy[sizeof(uart3_line_copy) - 1] = '\0';

            uart3_rx_index = 0;
            uart3_line_ready = 1;
        }
        else if (uart3_rx_byte != '\r')
        {
            if (uart3_rx_index < sizeof(uart3_rx_line) - 1)
            {
                uart3_rx_line[uart3_rx_index++] = (char)uart3_rx_byte;
            }
            else
            {
                uart3_rx_index = 0;
            }
        }

        UART3_StartReceiveIT();
    }
}

