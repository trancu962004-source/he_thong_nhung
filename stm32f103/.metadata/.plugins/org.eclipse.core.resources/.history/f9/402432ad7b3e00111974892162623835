int main(void)
{
  HAL_Init();
  SystemClock_Config();

  MX_GPIO_Init();
  MX_CAN_Init();
  MX_USART1_UART_Init();
  MX_USART2_UART_Init();
  MX_USART3_UART_Init();

  UART1_Print("STM32 start\r\n");
  UART1_Print("UART1 -> debug log\r\n");
  UART1_Print("UART2 -> RX from ESP1\r\n");
  UART1_Print("UART3 -> RX from ESP2\r\n");

  if (!CAN_Filter_Config_AllPass())
  {
      UART1_Print("CAN filter config failed\r\n");
      Error_Handler();
  }

  if (HAL_CAN_Start(&hcan) != HAL_OK)
  {
      UART1_Print("CAN start failed\r\n");
      Error_Handler();
  }

  UART1_Print("CAN started\r\n");

  UART2_StartReceiveIT();
  UART3_StartReceiveIT();

  UART1_Print("UART2 RX interrupt started\r\n");
  UART1_Print("UART3 RX interrupt started\r\n");

  while (1)
  {
      /* TEST CAN cố định mỗi 1 giây */
      {
          static uint32_t last_test_tick = 0;
          uint32_t now = HAL_GetTick();

          if ((now - last_test_tick) >= 1000)
          {
              PatientData_t test = {
                  .room = 1,
                  .bed = 2,
                  .hr = 88,
                  .spo2 = 97,
                  .temp_x10 = 368,
                  .valid = 1
              };

              last_test_tick = now;

              if (CAN_Send_Vitals(1, &test))
              {
                  UART1_Print("TEST CAN TX | SRC=1 ID=0x10A HR=88 SpO2=97 Temp_x10=368\r\n");
              }
              else
              {
                  UART1_Print("TEST CAN TX ERROR\r\n");
              }
          }
      }

      /* ===== ESP1 - UART2 ===== */
      if (uart2_line_ready)
      {
          uart2_line_ready = 0;

          if (Parse_UART_Line(uart2_line_copy, &g_patient_esp1))
          {
              g_tx_offset_ms_esp1 =
                  ((g_patient_esp1.room * 8U) + g_patient_esp1.bed) * 20U;

              char logbuf[180];
              snprintf(logbuf, sizeof(logbuf),
                       "PARSED UART2 | Room=%u Bed=%u HR=%u SpO2=%u Temp_x10=%d ID=0x%03X Offset=%lu\r\n",
                       g_patient_esp1.room,
                       g_patient_esp1.bed,
                       g_patient_esp1.hr,
                       g_patient_esp1.spo2,
                       g_patient_esp1.temp_x10,
                       Make_CAN_ID(1, g_patient_esp1.room, g_patient_esp1.bed),
                       (unsigned long)g_tx_offset_ms_esp1);
              UART1_Print(logbuf);
          }
          else
          {
              char logbuf[180];
              snprintf(logbuf, sizeof(logbuf),
                       "PARSE ERROR UART2 | RAW=[%s]\r\n", uart2_line_copy);
              UART1_Print(logbuf);
          }
      }

      /* ===== ESP2 - UART3 ===== */
      if (uart3_line_ready)
      {
          uart3_line_ready = 0;

          if (Parse_UART_Line(uart3_line_copy, &g_patient_esp2))
          {
              g_tx_offset_ms_esp2 =
                  ((g_patient_esp2.room * 8U) + g_patient_esp2.bed) * 20U + 10U;

              char logbuf[180];
              snprintf(logbuf, sizeof(logbuf),
                       "PARSED UART3 | Room=%u Bed=%u HR=%u SpO2=%u Temp_x10=%d ID=0x%03X Offset=%lu\r\n",
                       g_patient_esp2.room,
                       g_patient_esp2.bed,
                       g_patient_esp2.hr,
                       g_patient_esp2.spo2,
                       g_patient_esp2.temp_x10,
                       Make_CAN_ID(2, g_patient_esp2.room, g_patient_esp2.bed),
                       (unsigned long)g_tx_offset_ms_esp2);
              UART1_Print(logbuf);
          }
          else
          {
              char logbuf[180];
              snprintf(logbuf, sizeof(logbuf),
                       "PARSE ERROR UART3 | RAW=[%s]\r\n", uart3_line_copy);
              UART1_Print(logbuf);
          }
      }

      CAN_Task_One(1, &g_patient_esp1, &g_last_can_tx_esp1, g_tx_offset_ms_esp1);
      CAN_Task_One(2, &g_patient_esp2, &g_last_can_tx_esp2, g_tx_offset_ms_esp2);
  }
}

