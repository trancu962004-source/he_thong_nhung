/**
  ******************************************************************************
  * @file           : main.c
  * @brief          : STM32F103 UART2/UART3 -> CAN Extended Gateway
  *
  * Đã test phần cứng CAN với Standard ID 0x123.
  * File này là code chạy thật:
  *
  * ESP32 -> STM32 UART:
  *   TYPE=VITAL,W=B,R=1,B=2,P=3,HR=88,SPO2=97,T=36.8,BAT=90,SEQ=10
  *   TYPE=LOADCELL,W=B,R=1,B=2,P=3,ML=450,DPM=25,SEQ=101
  *
  * STM32 -> CAN:
  *   CAN Extended ID 29-bit:
  *     bit 28..26 : msg_type   1=VITAL, 2=LOADCELL
  *     bit 25..24 : wing       0=A, 1=B
  *     bit 23..16 : room       0..255
  *     bit 15..8  : bed        0..255
  *     bit 7..0   : patient    0..255
  *
  * CAN bitrate:
  *   125 kbps @ APB1 = 36 MHz
  *
  * UART:
  *   USART1: debug log 115200
  *   USART2: ESP32 #1 115200
  *   USART3: ESP32 #2 115200
  ******************************************************************************
  */
