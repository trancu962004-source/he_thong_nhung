int main(void)
{
    HAL_Init();
    SystemClock_Config();

    MX_GPIO_Init();
    MX_CAN_Init();
    MX_USART1_UART_Init();
    MX_USART2_UART_Init();
    MX_USART3_UART_Init();

    UART_Print("\r\n========================================\r\n");
    UART_Print("STM32 UART2/UART3 -> CAN EXT GATEWAY START\r\n");
    UART_Print("CAN bitrate: 125 kbps\r\n");
    UART_Print("USART1 debug: 115200\r\n");
    UART_Print("USART2 ESP1 : 115200\r\n");
    UART_Print("USART3 ESP2 : 115200\r\n");
    UART_Print("========================================\r\n");

    if (!CAN_Filter_Config_AllPass())
    {
        UART_Print("CAN filter config failed\r\n");
        Error_Handler();
    }

    if (HAL_CAN_Start(&hcan) != HAL_OK)
    {
        CAN_Print_Error("CAN start failed");
        Error_Handler();
    }

    UART_Print("CAN started\r\n");

    if (HAL_CAN_ActivateNotification(&hcan,
                                     CAN_IT_ERROR |
                                     CAN_IT_BUSOFF |
                                     CAN_IT_LAST_ERROR_CODE) != HAL_OK)
    {
        CAN_Print_Error("CAN notification failed");
        Error_Handler();
    }

    UART2_StartReceiveIT();
    UART3_StartReceiveIT();

    UART_Print("UART2/UART3 RX interrupt started\r\n");

#if ENABLE_CAN_EXT_TEST
    UART_Print("ENABLE_CAN_EXT_TEST = 1, STM32 will send ID=0x05010203 every 1 sec\r\n");
#else
    UART_Print("ENABLE_CAN_EXT_TEST = 0, waiting UART lines from ESP32\r\n");
#endif

    while (1)
    {
#if ENABLE_CAN_EXT_TEST
        CAN_Send_Ext_Test_Periodic();
#endif

        if (uart2_line_ready)
        {
            uart2_line_ready = 0;
            Process_UART_Line(uart2_line_copy, "UART2");
        }

        if (uart3_line_ready)
        {
            uart3_line_ready = 0;
            Process_UART_Line(uart3_line_copy, "UART3");
        }
    }
}

