void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{
    BaseType_t xHigherPriorityTaskWoken = pdFALSE;
    uint32_t notifyValue = 0;


    if(GPIO_Pin == GPIO_PIN_0) {
        notifyValue = 0x0001;
    }
    else if(GPIO_Pin == GPIO_PIN_1) {
        notifyValue = 0x0010;
    }
    else if(GPIO_Pin == GPIO_PIN_2) {
        notifyValue = 0x0100;
    }

    if(notifyValue != 0 && ButtonTaskHandle != NULL) {
        xTaskNotifyFromISR(ButtonTaskHandle, notifyValue, eSetBits, &xHigherPriorityTaskWoken);
        portYIELD_FROM_ISR(xHigherPriorityTaskWoken);
    }
}
void Button_Task_Func(void *pvParameters) {
	uint32_t notifyValue;
	    uint8_t userInput;
	    while(1) {
	        xTaskNotifyWait(0x00, ULONG_MAX, &notifyValue, portMAX_DELAY);

	        if(notifyValue & 0x0001) userInput = CHAR_SQUARE;    // 0
	        if(notifyValue & 0x0010) userInput = CHAR_TRIANGLE;  // 1
	        if(notifyValue & 0x0100) userInput = CHAR_CROSS;     // 2

	        xQueueSend(UserQueue, &userInput, 0);
    }
}
void LCD_Task_Func(void *pvParameters) {
	while(1) {
	        xSemaphoreTake(DisplayBinSem, portMAX_DELAY);

	        xSemaphoreTake(LCDMutex, portMAX_DELAY);

	        lcd_clear();
	        lcd_put_cur(0,0);
	        lcd_send_string(lcd_row1);

	        lcd_put_cur(1,0);
	        if (lcd_row2_len > 0) {
	            for(int i = 0; i < lcd_row2_len; i++) {
	                lcd_send_data(lcd_row2_game[i]);
	            }
	        } else {
	            lcd_send_string(lcd_row2_text);
	        }

	        xSemaphoreGive(LCDMutex);
    }
}
void Game_Task_Func(void *pvParameters) {
	while(1) {
	        // ----------------------------------------------------
	        // 1. SETUP VÒNG CHƠI MỚI
	        // ----------------------------------------------------
	        charsToGen = currentLevel + 2;
	        if(charsToGen > 10) charsToGen = 10;

	        // Set thời gian tương ứng với Level
	        uint32_t timeoutMs = 4000;
	        if(currentLevel >= 5 && currentLevel <= 7) timeoutMs = 7000;
	        else if(currentLevel >= 8) timeoutMs = 10000;

	        xQueueReset(GameQueue);
	        xQueueReset(UserQueue);

	        xSemaphoreTake(LCDMutex, portMAX_DELAY);
	        sprintf(lcd_row1, "LEVEL: %d", currentLevel);
	        lcd_row2_len = 0;
	        sprintf(lcd_row2_text, "Get ready...");
	        xSemaphoreGive(LCDMutex);
	        xSemaphoreGive(DisplayBinSem);

	        vTaskDelay(pdMS_TO_TICKS(1500));

	        // ----------------------------------------------------
	        // 2. SINH KÝ TỰ VÀ HIỂN THỊ
	        // ----------------------------------------------------
	        xSemaphoreTake(LCDMutex, portMAX_DELAY);
	        sprintf(lcd_row1, "MEMORIZE:");
	        lcd_row2_len = 0;
	        xSemaphoreGive(LCDMutex);

	        for(int i = 0; i < charsToGen; i++) {
	            if (xSemaphoreTake(GenCountSem, 0) == pdTRUE) {
	                uint8_t newChar = Utils_GetRandomChar();
	                xQueueSend(GameQueue, &newChar, 0);

	                xSemaphoreTake(LCDMutex, portMAX_DELAY);
	                lcd_row2_game[lcd_row2_len++] = newChar;
	                xSemaphoreGive(LCDMutex);

	                xSemaphoreGive(DisplayBinSem);
	                vTaskDelay(pdMS_TO_TICKS(500));
	            }
	        }

	        vTaskDelay(pdMS_TO_TICKS(1000));

	        for(int i = 0; i < charsToGen; i++) {
	            xSemaphoreGive(GenCountSem);
	        }

	        // ----------------------------------------------------
	        // 3. BÔI ĐEN VÀ BẮT ĐẦU TÍNH GIỜ
	        // ----------------------------------------------------
	        xSemaphoreTake(LCDMutex, portMAX_DELAY);
	        sprintf(lcd_row1, "YOUR TURN:");
	        lcd_row2_len = 0;
	        sprintf(lcd_row2_text, "");
	        xSemaphoreGive(LCDMutex);
	        xSemaphoreGive(DisplayBinSem);

	        xTimerChangePeriod(GameTimer, pdMS_TO_TICKS(timeoutMs), 0);
	        xTimerStart(GameTimer, 0);

	        // ----------------------------------------------------
	        // 4. CHỜ NGƯỜI DÙNG NHẬP VÀ KIỂM TRA
	        // ----------------------------------------------------
	        bool isGameOver = false;

	        for(int i = 0; i < charsToGen; i++) {
	            uint8_t expectedChar, userChar;

	            xQueueReceive(GameQueue, &expectedChar, portMAX_DELAY);


	            xQueueReceive(UserQueue, &userChar, portMAX_DELAY);

	            if(userChar == 0xFF) {
	                isGameOver = true;
	                break;
	            }

	            if(userChar != expectedChar) {
	                isGameOver = true;
	                break;
	            } else {

	                xSemaphoreTake(LCDMutex, portMAX_DELAY);
	                lcd_row2_game[lcd_row2_len++] = userChar;
	                xSemaphoreGive(LCDMutex);
	                xSemaphoreGive(DisplayBinSem);
	            }
	        }

	        xTimerStop(GameTimer, 0);

	        // ----------------------------------------------------
	        // 5. KẾT LUẬN THẮNG/THUA
	        // ----------------------------------------------------
	        if(isGameOver) {
	            xSemaphoreTake(LCDMutex, portMAX_DELAY);
	            sprintf(lcd_row1, "GAME OVER!");
	            lcd_row2_len = 0;
	            sprintf(lcd_row2_text, "Press any btn...");
	            xSemaphoreGive(LCDMutex);
	            xSemaphoreGive(DisplayBinSem);

	            uint8_t dummy;
	            xQueueReset(UserQueue);
	            xQueueReceive(UserQueue, &dummy, portMAX_DELAY);

	            currentLevel = 1; // Reset Level
	        } else {
	            xSemaphoreTake(LCDMutex, portMAX_DELAY);
	            sprintf(lcd_row1, "CORRECT!");
	            lcd_row2_len = 0;
	            sprintf(lcd_row2_text, "Next Level ->");
	            xSemaphoreGive(LCDMutex);
	            xSemaphoreGive(DisplayBinSem);

	            currentLevel++;
	            vTaskDelay(pdMS_TO_TICKS(2000));
	        }
    }
}
void GameTimerCallback(TimerHandle_t xTimer){
	    uint8_t timeoutSignal = 0xFF;
	    xQueueSend(UserQueue, &timeoutSignal, 0);
}
