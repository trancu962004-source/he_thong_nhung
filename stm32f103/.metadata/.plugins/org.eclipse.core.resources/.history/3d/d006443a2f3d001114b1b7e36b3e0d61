int main(void)
{
  uint8_t txData[8] = {0x11, 0x22, 0x33, 0x44, 0x55, 0x66, 0x77, 0x88};

  HAL_Init();
  SystemClock_Config();

  MX_GPIO_Init();
  MX_CAN_Init();
  MX_USART1_UART_Init();

  UART1_Print("\r\n========== STM32 CAN TX START ==========\r\n");

#ifdef CAN_TEST_LOOPBACK
  UART1_Print("MODE: LOOPBACK\r\n");
#else
  UART1_Print("MODE: NORMAL\r\n");
#endif

#ifdef CAN_BAUD_125K
  UART1_Print("CAN BAUD: 125 kbps\r\n");
#endif

#ifdef CAN_BAUD_500K
  UART1_Print("CAN BAUD: 500 kbps\r\n");
#endif

  CAN_Filter_Config_AllPass();

  if (HAL_CAN_Start(&hcan) != HAL_OK)
  {
    UART1_Print("HAL_CAN_Start failed\r\n");
    Error_Handler();
  }

  UART1_Print("HAL_CAN_Start OK\r\n");

  while (1)
  {
    if (CAN_Send_Frame_Std(0x123, txData, 8))
    {
      UART1_Print("TX OK -> ID=0x123 DLC=8 DATA=11 22 33 44 55 66 77 88\r\n");
    }
    else
    {
      UART1_Print("TX FAIL\r\n");
      CAN_Print_Status();
    }

    HAL_Delay(1000);
  }
}

