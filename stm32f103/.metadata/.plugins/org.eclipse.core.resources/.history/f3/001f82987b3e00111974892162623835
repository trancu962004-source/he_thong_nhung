static uint8_t Extract_Int_Field(const char *line, const char *key, int *value)
{
    const char *p;
    char *endptr;
    long v;

    if (line == NULL || key == NULL || value == NULL)
        return 0;

    p = strstr(line, key);
    if (p == NULL)
        return 0;

    p += strlen(key);
    v = strtol(p, &endptr, 10);

    if (endptr == p)
        return 0;

    *value = (int)v;
    return 1;
}

static uint8_t Extract_Float_Field(const char *line, const char *key, float *value)
{
    const char *p;

    if (line == NULL || key == NULL || value == NULL)
        return 0;

    p = strstr(line, key);
    if (p == NULL)
        return 0;

    p += strlen(key);
    *value = (float)atof(p);
    return 1;
}

/*
  Chỉ parse line VITAL:
  TYPE=VITAL,W=B,R=1,B=2,P=1,HR=88,SPO2=97,T=36.8,BAT=90,SEQ=10
*/
static uint8_t Parse_UART_Line(const char *line, PatientData_t *p)
{
    int room, bed, patient, hr, spo2, battery, seq;
    float temp_c;

    if (line == NULL || p == NULL)
        return 0;

    /* bỏ qua line không phải vital */
    if (strstr(line, "TYPE=VITAL") == NULL)
        return 0;

    if (!Extract_Int_Field(line, "R=", &room)) return 0;
    if (!Extract_Int_Field(line, "B=", &bed)) return 0;
    if (!Extract_Int_Field(line, "P=", &patient)) return 0;
    if (!Extract_Int_Field(line, "HR=", &hr)) return 0;
    if (!Extract_Int_Field(line, "SPO2=", &spo2)) return 0;
    if (!Extract_Float_Field(line, "T=", &temp_c)) return 0;
    if (!Extract_Int_Field(line, "BAT=", &battery)) battery = 0;
    if (!Extract_Int_Field(line, "SEQ=", &seq)) seq = 0;

    if (room < 0 || room > 31) return 0;
    if (bed < 0 || bed > 7) return 0;
    if (patient < 0 || patient > 255) return 0;
    if (hr < 0 || hr > 255) return 0;
    if (spo2 < 0 || spo2 > 100) return 0;
    if (temp_c < 20.0f || temp_c > 45.0f) return 0;
    if (battery < 0 || battery > 100) battery = 0;
    if (seq < 0 || seq > 255) seq = 0;

    p->room = (uint8_t)room;
    p->bed = (uint8_t)bed;
    p->patient = (uint8_t)patient;
    p->hr = (uint8_t)hr;
    p->spo2 = (uint8_t)spo2;
    p->temp_x10 = (int16_t)(temp_c * 10.0f + 0.5f);
    p->battery = (uint8_t)battery;
    p->seq = (uint8_t)seq;
    p->valid = 1;

    return 1;
}

/* source 1 -> 0x100, source 2 -> 0x200 */
static uint16_t Make_CAN_ID(uint8_t source, uint8_t room, uint8_t bed)
{
    uint16_t base = (source == 1U) ? 0x100U : 0x200U;
    return (uint16_t)(base | ((room & 0x1FU) << 3) | (bed & 0x07U));
}

/*
  DLC = 8:
  [0] patient
  [1] hr
  [2] spo2
  [3] temp_x10 low
  [4] temp_x10 high
  [5] battery
  [6] seq
  [7] source
*/
static void Pack_Vitals_DLC8(const PatientData_t *p, uint8_t data[8])
{
    data[0] = p->patient;
    data[1] = p->hr;
    data[2] = p->spo2;
    data[3] = (uint8_t)(p->temp_x10 & 0xFF);
    data[4] = (uint8_t)((p->temp_x10 >> 8) & 0xFF);
    data[5] = p->battery;
    data[6] = p->seq;
    data[7] = 0;
}

static uint8_t CAN_Filter_Config_AllPass(void)
{
    CAN_FilterTypeDef filter = {0};

    filter.FilterActivation = ENABLE;
    filter.FilterBank = 0;
    filter.FilterFIFOAssignment = CAN_FILTER_FIFO0;
    filter.FilterIdHigh = 0x0000;
    filter.FilterIdLow = 0x0000;
    filter.FilterMaskIdHigh = 0x0000;
    filter.FilterMaskIdLow = 0x0000;
    filter.FilterMode = CAN_FILTERMODE_IDMASK;
    filter.FilterScale = CAN_FILTERSCALE_32BIT;
    filter.SlaveStartFilterBank = 14;

    if (HAL_CAN_ConfigFilter(&hcan, &filter) != HAL_OK)
        return 0;

    return 1;
}

static uint8_t CAN_Send_Vitals(uint8_t source, const PatientData_t *p)
{
    CAN_TxHeaderTypeDef txHeader;
    uint8_t data[8];
    uint32_t txMailbox;

    if (p == NULL || p->valid == 0U)
        return 0;

    memset(&txHeader, 0, sizeof(txHeader));
    memset(data, 0, sizeof(data));

    txHeader.StdId = Make_CAN_ID(source, p->room, p->bed);
    txHeader.ExtId = 0;
    txHeader.IDE = CAN_ID_STD;
    txHeader.RTR = CAN_RTR_DATA;
    txHeader.DLC = 8;
    txHeader.TransmitGlobalTime = DISABLE;

    Pack_Vitals_DLC8(p, data);
    data[7] = source;

    if (HAL_CAN_GetTxMailboxesFreeLevel(&hcan) == 0U)
        return 0;

    if (HAL_CAN_AddTxMessage(&hcan, &txHeader, data, &txMailbox) != HAL_OK)
        return 0;

    return 1;
}

static void CAN_Task_One(uint8_t source,
                         const PatientData_t *p,
                         uint32_t *last_tx,
                         uint32_t tx_offset_ms)
{
    uint32_t now;
    char logbuf[200];

    if ((p == NULL) || (last_tx == NULL) || (p->valid == 0U))
        return;

    now = HAL_GetTick();

    if (now < tx_offset_ms)
        return;

    if ((now - *last_tx) >= g_tx_period_ms)
    {
        *last_tx = now;

        if (CAN_Send_Vitals(source, p))
        {
            snprintf(logbuf, sizeof(logbuf),
                     "CAN TX | SRC=%u ID=0x%03X P=%u HR=%u SpO2=%u Temp_x10=%d BAT=%u SEQ=%u\r\n",
                     source,
                     Make_CAN_ID(source, p->room, p->bed),
                     p->patient,
                     p->hr,
                     p->spo2,
                     p->temp_x10,
                     p->battery,
                     p->seq);
        }
        else
        {
            snprintf(logbuf, sizeof(logbuf),
                     "CAN TX ERROR | SRC=%u ID=0x%03X\r\n",
                     source,
                     Make_CAN_ID(source, p->room, p->bed));
        }

        UART1_Print(logbuf);
    }
}

void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart)
{
    if (huart->Instance == USART2)
    {
        if (uart2_rx_byte == '\n')
        {
            uart2_rx_line[uart2_rx_index] = '\0';
            strncpy(uart2_line_copy, uart2_rx_line, sizeof(uart2_line_copy) - 1U);
            uart2_line_copy[sizeof(uart2_line_copy) - 1U] = '\0';

            uart2_rx_index = 0;
            uart2_line_ready = 1;
        }
        else if (uart2_rx_byte != '\r')
        {
            if (uart2_rx_index < (sizeof(uart2_rx_line) - 1U))
            {
                uart2_rx_line[uart2_rx_index++] = (char)uart2_rx_byte;
            }
            else
            {
                uart2_rx_index = 0;
            }
        }

        UART2_StartReceiveIT();
    }
    else if (huart->Instance == USART3)
    {
        if (uart3_rx_byte == '\n')
        {
            uart3_rx_line[uart3_rx_index] = '\0';
            strncpy(uart3_line_copy, uart3_rx_line, sizeof(uart3_line_copy) - 1U);
            uart3_line_copy[sizeof(uart3_line_copy) - 1U] = '\0';

            uart3_rx_index = 0;
            uart3_line_ready = 1;
        }
        else if (uart3_rx_byte != '\r')
        {
            if (uart3_rx_index < (sizeof(uart3_rx_line) - 1U))
            {
                uart3_rx_line[uart3_rx_index++] = (char)uart3_rx_byte;
            }
            else
            {
                uart3_rx_index = 0;
            }
        }

        UART3_StartReceiveIT();
    }
}

